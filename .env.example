# Endpoints LLM (vLLM con API OpenAI-compatible)
# Sustituir <LLM_SERVER_HOST> por el host o IP del servidor donde esté desplegado el modelo.

GPT_OSS_URL=http://<LLM_SERVER_HOST>:8000/v1
GPT_OSS_URL_B=http://<LLM_SERVER_HOST>:8001/v1
GEMMA_URL=http://<LLM_SERVER_HOST>:8003/v1

# Nombres EXACTOS tal como están registrados en vLLM.
# Verifícalo con: curl http://<LLM_SERVER_HOST>:8000/v1/models
GPT_OSS_MODEL=<model-name>
GEMMA_MODEL=<model-name>
